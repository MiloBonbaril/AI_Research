{"nodes": [{"id": "claude", "label": "CLAUDE.md \u2014 RSI-Research Project Guide", "file_type": "document", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_memora", "label": "Memora (hybrid sub-quadratic architecture)", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Combines LocalAttention (sliding-window + GQA + RoPE + QK-Norm) with GatedLinearAttention (GLA) recurrent layers for unbounded context at ~126M params. Critical invariant: the chunked training path (_chunked) and recurrent reference (_recurrent) must stay numerically equivalent, asserted in models/memora.py __main__; GLA stability comes from never materializing absolute e^{-Gc}, only bounded differences Gc_i - Gc_j <= 0. GLA layers deliberately skip RoPE since position lives in the recurrent state."}, {"id": "concept_gated_linear_attention", "label": "Gated Linear Attention (GLA)", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Linear attention with a fixed-size recurrent state used by Memora's recurrent_layers for unbounded context; chunked-training and recurrent-inference paths must remain numerically equivalent (regression-guarded)."}, {"id": "concept_rope", "label": "RoPE (Rotary Position Embedding)", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_wsd_schedule", "label": "WSD schedule (Warmup-Stable-Decay)", "file_type": "concept", "source_file": "CLAUDE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_adamw", "label": "AdamW optimizer", "file_type": "concept", "so